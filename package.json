{
  "name": "@mrijke/greenlight",
  "version": "0.1.0",
  "description": "Terminal UI for your open PRs and their CI checks",
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "license": "MIT",
  "author": "Maarten Rijke <maartenrijke@gmail.com>",
  "homepage": "https://github.com/mrijke/greenlight#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrijke/greenlight.git"
  },
  "bugs": {
    "url": "https://github.com/mrijke/greenlight/issues"
  },
  "keywords": [
    "cli",
    "tui",
    "ink",
    "github",
    "pull-requests",
    "ci",
    "github-actions"
  ],
  "bin": {
    "greenlight": "dist/cli.js",
    "gl": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "execa": "9.6.1",
    "ink": "7.1.0",
    "ink-spinner": "5.0.0",
    "octokit": "5.0.5",
    "openai": "6.45.0",
    "react": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "ink-testing-library": "4.0.0",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.1.1",
    "vitest": "4.1.9"
  }
}
